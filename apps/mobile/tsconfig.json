{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@mobile/*": ["src/*"],
      "@sozorock-health/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": [
    "App.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../packages/shared/src/**/*.ts"
  ]
}
