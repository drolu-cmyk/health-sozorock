{
  "name": "health-sozorock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "test": "node --test tests/*.test.mjs",
    "typecheck": "next typegen && tsc --noEmit",
    "build": "next build",
    "guardrails": "node scripts/guardrail-scan.mjs",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run guardrails && npm audit --audit-level=moderate"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "postcss": "8.5.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "postcss": "8.5.14",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
